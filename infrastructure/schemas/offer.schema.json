{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sqwod.life/schemas/offer.schema.json",
  "title": "Sqwod Verified Offer",
  "description": "A single merchant offer for a product, aggregated from an affiliate network. Many offers attach to one product node; the best in-stock offer powers the Value score and the Best deal button.",
  "type": "object",
  "required": ["offerId", "productId", "network", "merchant", "price", "currency", "url", "inStock", "lastChecked"],
  "properties": {
    "offerId":   { "type": "string", "description": "Stable id; used in /go/{offerId}" },
    "productId": { "type": "string", "description": "FK to the product node" },
    "network":   { "type": "string", "enum": ["amazon", "awin", "impact", "cj", "rakuten", "sovrn", "direct"] },
    "merchant":  { "type": "string", "description": "Storefront name, e.g. 'Amazon.de', 'Oura'" },
    "market":    { "type": "string", "enum": ["de", "eu", "uk", "com", "global"] },
    "price":     { "type": "number", "minimum": 0 },
    "shipping":  { "type": ["number", "null"] },
    "currency":  { "type": "string", "enum": ["EUR", "USD", "GBP"] },
    "url":       { "type": "string", "format": "uri", "description": "Raw merchant/affiliate deep link (wrapped by /go at render)" },
    "inStock":   { "type": "boolean" },
    "condition": { "type": "string", "enum": ["new", "refurbished", "used"], "default": "new" },
    "isSubscription": { "type": "boolean", "default": false, "description": "Flag recurring costs so 'price' stays honest" },
    "subscriptionNote": { "type": ["string", "null"], "description": "e.g. 'requires €70/yr membership'" },
    "lastChecked": { "type": "string", "format": "date-time" },
    "priceHistory": {
      "type": "array",
      "description": "Append-only; powers the sparkline + '90-day low'",
      "items": {
        "type": "object",
        "required": ["date", "price"],
        "properties": {
          "date":  { "type": "string", "format": "date" },
          "price": { "type": "number" }
        }
      }
    },
    "source": { "type": "string", "description": "Provenance ref for the wiki (which feed/api call)" }
  }
}
