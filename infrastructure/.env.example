# Sqwod Verified — secrets template
# Copy to .env (which is git-ignored) and fill real values.
# Hand Tee this list when joining each network.

# --- Amazon Associates / Product Advertising API ---
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
# partner tags live in affiliate-networks.yaml (not secret)

# --- Awin ---
AWIN_API_TOKEN=

# --- Impact.com ---
IMPACT_AUTH_TOKEN=

# --- CJ (Commission Junction) ---
CJ_API_KEY=

# --- Rakuten Advertising ---
RAKUTEN_CLIENT_ID=
RAKUTEN_CLIENT_SECRET=

# --- Sovrn Commerce (Skimlinks) — gap-fill ---
SOVRN_API_KEY=

# --- (optional) AI image-to-3D provider for hero product .glb generation ---
IMAGE_TO_3D_API_KEY=

# --- internal ---
GO_REDIRECT_SECRET=        # signs/validates outbound /go links
