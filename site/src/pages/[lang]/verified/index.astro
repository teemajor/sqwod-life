---
import Base from '../../../layouts/Base.astro';
import Glyph from '../../../components/Glyph.astro';
import { getCollection } from 'astro:content';
import { languages, t, type Lang } from '../../../i18n/ui';
import { categories } from '../../../config/verified-categories';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const reviews = await getCollection('reviews', (r) => r.data.lang === lang);
const reviewedSlugs = new Set(reviews.map((r) => r.data.urlSlug));

const cards = categories.map((c) => ({
  c,
  reviewed: c.picks.filter((p) => p.reviewSlug && reviewedSlugs.has(p.reviewSlug)).length,
  total: c.picks.length,
  names: c.picks.slice(0, 4).map((p) => p.brand),
}));
const totalReviewed = reviews.length;

const title = lang === 'de' ? 'Sqwod Verified — Kaufberatung für Wellness & Fitness' : 'Sqwod Verified — Wellness & Fitness Buyer\'s Guides';
const blurb = lang === 'de'
  ? 'Ehrliche, methodische Kaufberatung für die Fitness- & Wellness-Branche. Getestete Produkte tragen einen Sqwod Score; Redaktions-Tipps sind kuratierte Marktführer. Affiliate-Links sind gekennzeichnet — die Wahrheit gewinnt.'
  : 'Honest, methodology-driven buyer\'s guides for the fitness & wellness industry. Reviewed products carry a Sqwod Score; editorial picks are curated leaders. Affiliate links are labeled — truth wins.';
---
<Base lang={lang} title={title} description={blurb} active="verified">
  <div class="crumb">Sqwod Verified</div>
  <span class="verified-tag reveal">◈ Sqwod Verified</span>
  <h1 class="reveal d1" style="margin:2px 0 6px">{lang==='de'?'Kaufberatung, der man trauen kann':'Buyer\'s guides you can trust'}</h1>
  <p class="sub reveal d2" style="max-width:64ch">{blurb}</p>
  <p class="sub reveal d2" style="margin-top:6px">
    <a href={`/${lang}/verified/methodology`} style="color:var(--chalk)">{t(lang,'verified.howWeRank')} →</a>
    &nbsp;·&nbsp; <b>{totalReviewed}</b> {lang==='de'?'getestet':'reviewed'} &nbsp;·&nbsp; <b>{categories.length}</b> {lang==='de'?'Kategorien':'categories'}
  </p>

  <div class="cat-grid">
    {cards.map(({ c, reviewed, total, names }, i) => (
      <a class={`cat reveal d${(i % 6) + 1}`} href={`/${lang}/verified/c/${c.slug}`}>
        <div class="cat-ic"><Glyph kind={c.glyph} size={46} /></div>
        <div class="cat-body">
          <h3>{c.label[lang]}</h3>
          <p>{c.blurb[lang]}</p>
          <div class="cat-meta">
            {reviewed > 0 && <span class="pill rev">{reviewed} {lang==='de'?'getestet':'reviewed'}</span>}
            <span class="pill">{total} {lang==='de'?'Picks':'picks'}</span>
            <span class="brands">{names.join(' · ')}</span>
          </div>
          <span class="cat-cta">{lang==='de'?'Guide ansehen':'See the guide'} →</span>
        </div>
      </a>
    ))}
  </div>

  <p class="disc" style="margin-top:18px">{t(lang,'disclosure')}</p>
</Base>

<style>
  .cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:20px}
  .cat{display:grid;grid-template-columns:46px 1fr;gap:16px;align-items:start;border:1px solid var(--line);border-radius:16px;padding:20px;text-decoration:none;background:var(--panel);transition:border-color .15s ease,transform .15s ease}
  .cat:hover{border-color:var(--chalk);transform:translateY(-2px)}
  .cat-body h3{font-size:18px;letter-spacing:-.01em;margin:0 0 6px;color:var(--chalk)}
  .cat-body p{font-size:13.5px;color:var(--g2);line-height:1.5;margin:0 0 12px}
  .cat-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:12px}
  .pill{font-size:10px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--g3);border:1px solid var(--line);border-radius:999px;padding:3px 9px}
  .pill.rev{background:var(--chalk);color:var(--ink);border-color:var(--chalk)}
  .brands{font-size:12px;color:var(--g4)}
  .cat-cta{font-size:13px;font-weight:700;color:var(--chalk)}
  @media(max-width:680px){.cat-grid{grid-template-columns:1fr}}
</style>
