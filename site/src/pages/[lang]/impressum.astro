---
import Base from '../../layouts/Base.astro';
import { languages, type Lang } from '../../i18n/ui';
export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
---
<Base lang={lang} title="Impressum — Sqwod" active="">
  <h1 style="margin-top:36px">Impressum</h1>
  <div class="prose">
    <p>{lang==='de'
      ? 'Angaben gemäß § 5 TMG. (Platzhalter — echte Anbieterkennzeichnung vor dem Launch ergänzen: Name, Anschrift, Kontakt, USt-IdNr., Verantwortliche:r i.S.d. § 18 Abs. 2 MStV.)'
      : 'Information pursuant to § 5 TMG (German law). (Placeholder — add real provider details before launch: name, address, contact, VAT ID, responsible party.)'}</p>
    <p>Sqwod · Berlin · tee@sqwod.life</p>
  </div>
</Base>
