---
import Base from '../../layouts/Base.astro';
import { languages, type Lang } from '../../i18n/ui';
import { SUBSCRIBE } from '../../config/subscribe';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
// NOTE: this page is prerendered — query params like ?status= (set by the Worker
// redirect) do NOT exist at build time. Both banners are rendered hidden and
// toggled client-side by the inline script below.
const c = lang === 'de' ? {
  title: 'Werde schärfer — in 5 Minuten am Tag',
  blurb: 'Sqwod Daily: das Business von Fitness und Wellness, werktäglich aufbereitet — Geldbewegungen, die Lektion hinter den News, ein To-do, etwas Unterhaltung. Kostenlos.',
  perks: ['Werktäglich, zweisprachig (EN & DE)', 'Geldbewegungen, Politik-Radar & Stats', 'Ein umsetzbarer Tipp pro Ausgabe', 'Lesen oder hören — Audio zu jeder Ausgabe'],
  email: 'E-Mail-Adresse', cta: 'Kostenlos abonnieren', soon: 'Anmeldung wird in Kürze aktiviert.',
  fine: 'Mit der Anmeldung akzeptierst du unsere Datenschutzbestimmungen. Abmeldung jederzeit.',
  ok: 'Drin! Check dein Postfach — die nächste Ausgabe kommt am nächsten Werktag.',
  err: 'Hmm, das hat nicht geklappt. Prüf die E-Mail-Adresse und versuch es nochmal.',
} : {
  title: 'Get sharper in 5 minutes a day',
  blurb: 'Sqwod Daily: the business of fitness and wellness, decoded every weekday — money movement, the lesson behind the news, one thing to do, a little fun. Free.',
  perks: ['Every weekday, bilingual (EN & DE)', 'Money movement, policy watch & stats', 'One actionable takeaway per issue', 'Read it or hear it — audio with every issue'],
  email: 'Email address', cta: 'Subscribe free', soon: 'Sign-up goes live shortly.',
  fine: 'By subscribing you accept our privacy policy. Unsubscribe anytime.',
  ok: "You're in! Check your inbox — the next issue lands on the next weekday.",
  err: "Hmm, that didn't go through. Check the email address and try again.",
};
---
<Base lang={lang} title={c.title + ' — Sqwod'} description={c.blurb} active="">
  <div class="sub-hero">
    <div class="sh-copy">
      <h1>{c.title}</h1>
      <p class="sub">{c.blurb}</p>
      <ul class="perks">{c.perks.map((p) => <li>{p}</li>)}</ul>
    </div>
    <div class="sh-form">
      <div class="banner ok" id="banner-ok" hidden role="status">{c.ok}</div>
      <div class="banner err" id="banner-err" hidden role="alert">{c.err}</div>
      <form class="bform" method="post" action={SUBSCRIBE.endpoint || '#'}>
        <input type="hidden" name="lang" value={lang} />
        <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
        <label>{c.email}<input type="email" name="email" required placeholder="you@studio.com" /></label>
        <button class="cta" type="submit" disabled={!SUBSCRIBE.endpoint} data-umami-event="subscribe" data-umami-event-where="subscribe-page">{c.cta}</button>
        {!SUBSCRIBE.endpoint && <p class="note">{c.soon}</p>}
        <p class="fine">{c.fine}</p>
      </form>
    </div>
  </div>

  <script is:inline>
    // Prefill the email from the ?email= handed off by the homepage quick-capture
    // forms, and show the success/error banner from the Worker's ?status= redirect.
    // (Must run client-side: the page is prerendered, so build-time code never
    // sees query params.)
    (function () {
      try {
        var q = new URLSearchParams(location.search);
        var e = q.get('email');
        if (e) { var i = document.querySelector('.bform input[name="email"]'); if (i) i.value = e; }
        var s = q.get('status');
        var el = s === 'ok' ? document.getElementById('banner-ok')
               : s === 'error' ? document.getElementById('banner-err')
               : null;
        if (el) el.hidden = false;
      } catch (_) {}
    })();
  </script>
</Base>

<style>
  .sub-hero{display:grid;grid-template-columns:1.1fr .9fr;gap:32px;align-items:center;padding:10px 0 8px}
  .sh-copy h1{font-size:clamp(28px,4.5vw,40px);letter-spacing:-.02em;line-height:1.05;margin:0 0 12px}
  .perks{list-style:none;margin:18px 0 0;padding:0}
  .perks li{position:relative;padding-left:24px;margin:0 0 10px;color:var(--g1);font-size:15px}
  .perks li::before{content:"✓";position:absolute;left:0;color:var(--chalk);font-weight:800}
  .sh-form{border:1px solid var(--line);border-radius:18px;padding:26px;background:linear-gradient(180deg,var(--panel),transparent)}
  .bform{display:flex;flex-direction:column;gap:14px}
  .bform label{display:flex;flex-direction:column;gap:7px;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--g3)}
  .bform input{background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:13px 14px;color:var(--chalk);font:inherit;text-transform:none;letter-spacing:0}
  .bform input:focus{outline:none;border-color:var(--chalk)}
  .bform .cta[disabled]{opacity:.5;cursor:not-allowed}
  .hp{position:absolute;left:-9999px;width:1px;height:1px;opacity:0}
  .banner{border-radius:10px;padding:12px 14px;font-size:14px;line-height:1.5;margin:0 0 16px}
  .banner.ok{background:rgba(31,125,77,.14);border:1px solid rgba(31,125,77,.45);color:var(--chalk)}
  .banner.err{background:rgba(179,38,30,.14);border:1px solid rgba(179,38,30,.45);color:var(--chalk)}
  .note{font-size:13px;color:var(--g2);margin:0}
  .fine{font-size:11.5px;color:var(--g4);line-height:1.5;margin:4px 0 0}
  @media(max-width:680px){.sub-hero{grid-template-columns:1fr;gap:22px}}
</style>
