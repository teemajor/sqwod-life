---
import Base from '../../../layouts/Base.astro';
import ArticleView from '../../../components/ArticleView.astro';
import { getCollection } from 'astro:content';
import { type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const arts = await getCollection('articles', (a) => a.data.format === 'report' || a.data.format === 'index');
  return arts.map((entry) => ({ params: { lang: entry.data.lang, slug: entry.data.urlSlug }, props: { entry } }));
}
const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
---
<Base lang={lang} title={`${entry.data.title} — Sqwod Intelligence`} description={entry.data.description} active="intelligence">
  <div class="measure"><ArticleView lang={lang} entry={entry} sectionLabel="Sqwod Intelligence" /></div>
</Base>
