---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { languages, t, type Lang } from '../../../i18n/ui';
import { APPLE_URL, SPOTIFY_URL, rssFor, episodeAudio } from '../../../config/podcast';
import { existsSync } from 'node:fs';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const hasAudio = (slug: string) => existsSync(new URL(`../../../../public${episodeAudio(slug, lang)}`, import.meta.url));

const issues = (await getCollection('daily', (i) => i.data.lang === lang && i.data.status === 'published'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = issues[0];
const fmt = (d: Date) => d.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
const epLine = (iss: typeof issues[number]) => iss.data.summary || iss.data.items.map((i) => i.headline).join(' · ');
const blurb = lang === 'de'
  ? 'Dein 5-Minuten-Audio-Rundown der Wellness-Branche — jeden Werktag, auf EN & DE.'
  : 'Your 5-minute audio rundown of the wellness industry — every weekday, in EN & DE.';
const RSS_URL = rssFor(lang);
---
<Base lang={lang} title={lang==='de'?'Sqwod Daily — täglicher Audio-Brief':'Sqwod Daily — daily audio brief'} description={blurb} active="daily">
  <div class="crumb">Sqwod Daily</div>

  <div class="audio-hero">
    <div class="audio-meta">
      <h1 style="margin:0 0 6px">Sqwod Daily</h1>
      <p class="sub" style="margin:0 0 14px">{blurb}</p>
      <div class="listen">
        <span class="ll">{lang==='de'?'Hören auf':'Listen on'}:</span>
        {APPLE_URL !== '#' && <a class="lp" href={APPLE_URL} target="_blank" rel="noopener">Apple&nbsp;Podcasts</a>}
        {SPOTIFY_URL !== '#' && <a class="lp" href={SPOTIFY_URL} target="_blank" rel="noopener">Spotify</a>}
        <a class="lp" href={RSS_URL} target="_blank" rel="noopener">RSS</a>
        <a class="lp sub-cta" href={`/${lang}/subscribe`}>{lang==='de'?'Per E-Mail':'By email'}</a>
      </div>
    </div>
  </div>

  <section class="block" style="border-top:1px solid var(--line);margin-top:18px">
    <p class="kick">{lang==='de'?'Alle Folgen':'All episodes'}</p>
    <div class="ep-list">
      {issues.map((iss) => {
        const ha = hasAudio(iss.data.urlSlug);
        const url = `/${lang}/daily/${iss.data.urlSlug}`;
        return (
          <div class={`ep-row${ha ? '' : ' noaudio'}`}>
            <a class="ep-main" href={url}>
              <span class="ep-date">{fmt(iss.data.date)}</span>
              <span class="ep-title">
                {epLine(iss)}
                {iss.data.status !== 'published' && <span class="ep-draft">{lang==='de'?'Entwurf':'Draft'}</span>}
              </span>
            </a>
            <span class="ep-actions">
              <a class="ep-btn read" href={url}>{lang==='de'?'Lesen':'Read'}</a>
              {ha && (
                <a class="ep-btn listen" href={`${url}#listen`}>
                  <span class="ep-play">▶</span>{lang==='de'?'Hören':'Listen'}<span class="ep-dur">· {iss.data.duration ?? '5 min'}</span>
                </a>
              )}
            </span>
          </div>
        );
      })}
    </div>
  </section>

  {!latest && <p class="sub">{lang==='de'?'Noch keine Folge.':'No episodes yet.'}</p>}
</Base>

<style>
  .ep-list{border-top:1px solid var(--line)}
  .ep-row{display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center;
    padding:18px 6px;border-bottom:1px solid var(--line);transition:background .15s ease}
  .ep-row:hover{background:var(--panel)}
  .ep-main{display:grid;grid-template-columns:130px 1fr;gap:18px;align-items:center;text-decoration:none;min-width:0}
  .ep-date{font-size:12px;letter-spacing:.04em;color:var(--g3);font-family:ui-monospace,Menlo,monospace;white-space:nowrap}
  .ep-title{font-size:16px;font-weight:700;color:var(--chalk);line-height:1.3}
  .ep-draft{font-size:9px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);background:var(--g3);border-radius:4px;padding:2px 6px;margin-left:8px;vertical-align:middle}
  .ep-actions{display:flex;gap:8px;align-items:center;white-space:nowrap}
  .ep-btn{display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:700;letter-spacing:.02em;
    border:1px solid var(--line);border-radius:999px;padding:7px 14px;text-decoration:none;color:var(--g2);transition:all .15s ease}
  .ep-btn:hover{border-color:var(--chalk);color:var(--chalk)}
  .ep-btn.listen{color:var(--chalk)}
  .ep-btn.listen:hover{background:var(--chalk);color:var(--ink)}
  .ep-play{font-size:8px}
  .ep-dur{color:var(--g3);font-weight:600;font-family:ui-monospace,Menlo,monospace}
  .ep-btn.listen:hover .ep-dur{color:var(--ink)}
  @media(max-width:600px){
    .ep-row{grid-template-columns:1fr;gap:12px}
    .ep-main{grid-template-columns:1fr;gap:4px}
    .ep-date{order:-1}
    .ep-actions{justify-content:flex-start}
  }
</style>
