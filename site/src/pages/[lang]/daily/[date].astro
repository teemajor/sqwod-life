---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { type Lang } from '../../../i18n/ui';
import { pillarMeta } from '../../../i18n/pillars';
import { APPLE_URL, SPOTIFY_URL, rssFor, episodeAudio } from '../../../config/podcast';
import ShareBar from '../../../components/ShareBar.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  // Only build published editions — drafts stay off the live site.
  const issues = (await getCollection('daily')).filter((iss) => iss.data.status === 'published');
  return issues.map((iss) => ({
    params: { lang: iss.data.lang, date: iss.data.urlSlug },
    props: { entry: iss },
  }));
}
const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const d = entry.data;
const fmt = d.date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });

// Show the player only if the episode's audio actually exists in the build.
const audioPath = episodeAudio(d.urlSlug, lang);
const hasAudio = existsSync(join(process.cwd(), 'public', 'audio', `${d.urlSlug}-${lang}.mp3`));

const pillarLabel = (p: string) => pillarMeta[p as keyof typeof pillarMeta]?.label[lang] ?? p;
// Quiet provenance: items that carry a source link become numbered sources.
const sources = d.items.filter((i) => i.readMore);
const tx = {
  dots: lang === 'de' ? 'Punkte verbinden' : 'Connect the dots',
  recs: lang === 'de' ? 'Sqwod-Tipps' : 'Sqwod recs',
  ad: lang === 'de' ? 'Anzeige' : 'Sponsored',
  doThis: lang === 'de' ? 'Mach das heute' : 'Do this today',
  meanwhile: lang === 'de' ? 'Nebenbei in der Fitnesswelt' : 'Meanwhile in fitness',
  inToday: lang === 'de' ? 'In dieser Folge' : "In today's episode",
  listen: lang === 'de' ? 'Hören auf' : 'Listen on',
  byEmail: lang === 'de' ? 'Per E-Mail' : 'By email',
  subH: lang === 'de' ? 'Bekomm Sqwod Daily in dein Postfach' : 'Get Sqwod Daily in your inbox',
  subP: lang === 'de' ? 'Fünf Minuten, jeden Werktag. Was sich in der Branche bewegt — und was es für dich heißt. Kostenlos.' : 'Five minutes, every weekday. What moved in the industry — and what it means for you. Free.',
  subBtn: lang === 'de' ? 'Kostenlos abonnieren' : 'Subscribe free',
  sources: lang === 'de' ? 'Quellen' : 'Sources',
  draft: lang === 'de' ? 'Entwurf — Freigabe ausstehend' : 'Draft — pending approval',
};

// --- SEO / GEO: a unique title + description per issue (not the boilerplate
// intro), plus NewsArticle structured data so each episode is its own citable,
// rich-result-eligible page. The one-line `summary` drives all of it. ---
const epTitle = d.summary || d.title;
const metaTitle = `${epTitle} — Sqwod Daily`;
const dots = d.connectDots?.body?.replace(/\s+/g, ' ').trim();
let metaDesc = [d.summary, dots || d.items.map((i) => i.headline).join(' · ')].filter(Boolean).join(' — ');
if (metaDesc.length > 200) metaDesc = metaDesc.slice(0, 199).trimEnd() + '…';
const canonical = new URL(`/${lang}/daily/${d.urlSlug}/`, Astro.site).toString();
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: epTitle,
  description: metaDesc,
  image: new URL('/podcast-cover.png', Astro.site).toString(),
  datePublished: d.date.toISOString(),
  dateModified: d.date.toISOString(),
  inLanguage: lang,
  isAccessibleForFree: true,
  articleSection: 'Fitness & wellness business',
  author: { '@type': 'Organization', name: 'Sqwod Daily', url: new URL(`/${lang}/daily`, Astro.site).toString() },
  publisher: { '@type': 'Organization', name: 'sqwod.life', url: Astro.site?.toString() },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  url: canonical,
};
if (hasAudio) jsonLd.audio = { '@type': 'AudioObject', name: epTitle, contentUrl: new URL(audioPath, Astro.site).toString(), encodingFormat: 'audio/mpeg' };
---
<Base lang={lang} title={metaTitle} description={metaDesc} ogType="article" image="/podcast-cover.png">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <div class="crumb"><a href={`/${lang}/daily`}>← Sqwod Daily</a></div>
  <h1 style="margin:0 0 6px">Sqwod Daily</h1>
  <p class="sub" style="margin:0 0 16px">{fmt} · {d.edition}</p>
  {d.status !== 'published' && <p class="dealnote">⚑ {tx.draft}</p>}

  {d.intro && <p class="verdict" style="margin-bottom:14px">{d.intro}</p>}

  <ShareBar path={`/${lang}/daily/${d.urlSlug}`} title={d.connectDots?.title || d.summary || `Sqwod Daily — ${fmt}`} lang={lang} />

  <!-- LISTEN: embedded player + link-outs to the podcast apps -->
  <section class="player" id="listen">
    {hasAudio && <audio controls preload="none" src={audioPath} style="width:100%"></audio>}
    <div class="listen">
      <span class="ll">{tx.listen}:</span>
      {APPLE_URL !== '#' && <a class="lp" href={APPLE_URL} target="_blank" rel="noopener">Apple&nbsp;Podcasts</a>}
      {SPOTIFY_URL !== '#' && <a class="lp" href={SPOTIFY_URL} target="_blank" rel="noopener">Spotify</a>}
      <a class="lp" href={rssFor(lang)} target="_blank" rel="noopener">RSS</a>
    </div>
  </section>

  {d.move && d.move.url && (
    <section class="movecard">
      <p class="kick">{lang==='de'?'Move des Tages':'Move of the Day'}</p>
      {d.move.note && <p class="move-note">{d.move.note}</p>}
      <a class="move-link" href={d.move.url} target="_blank" rel="nofollow noopener">
        {lang==='de'?'Ansehen auf':'Watch on'} {d.move.platform || 'social'} →
      </a>
      {d.move.handle && <span class="move-credit">{lang==='de'?'Coach:':'Coach:'} {d.move.handle}</span>}
    </section>
  )}

  <!-- CONNECT THE DOTS: the teaching lead -->
  {d.connectDots && (
    <section class="dots">
      <p class="kick">{tx.dots}</p>
      <h2>{d.connectDots.title}</h2>
      {d.connectDots.body.split('\n').filter(Boolean).map((p) => <p class="dotbody">{p}</p>)}
    </section>
  )}

  <!-- THE BRIEF: readable digest, no per-item click-outs -->
  <section class="block" style="margin-top:8px">
    <p class="kick">{tx.inToday}</p>
    <ol class="digest">
      {d.items.map((item, i) => (
        <li>
          <span class="dn">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <span class="pillar-chip">{pillarLabel(item.pillar)}</span>
            <h3>{item.headline}</h3>
            <p class="dek">{item.dek}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- DO THIS: actionable -->
  {d.doThis && (
    <section class="dothis">
      <p class="kick">{tx.doThis}</p>
      <div class="dothis-box">{d.doThis}</div>
    </section>
  )}

  <!-- SQWOD RECS: curated actionable (incl. affiliate) -->
  {d.recs && d.recs.length > 0 && (
    <section class="recs">
      <p class="kick">{tx.recs}</p>
      <ul class="reclist">
        {d.recs.map((r) => (
          <li>
            <b>{r.label}:</b>{' '}
            {r.url
              ? <a href={r.affiliate && !r.url.startsWith('http') ? r.url : r.url} rel={r.affiliate ? 'sponsored nofollow' : undefined}>{r.text}</a>
              : r.text}
            {r.affiliate && <span class="recad">· {tx.ad}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- MEANWHILE: entertainment -->
  {d.meanwhile && (
    <section class="mw">
      <p class="kick">{tx.meanwhile}</p>
      <p class="mwbody">{d.meanwhile}</p>
    </section>
  )}

  <!-- SPONSOR (matches the audio read + email block) -->
  {d.sponsor && (
    <aside class="sponsor">
      <span class="adlabel">{lang==='de'?'Anzeige':'Sponsored'} · {lang==='de'?'Präsentiert von':'Presented by'} {d.sponsor.name}</span>
      {d.sponsor.blurb && <p>{d.sponsor.blurb}</p>}
      {d.sponsor.url && <a class="lp" href={d.sponsor.url} rel="sponsored nofollow" target="_blank">{d.sponsor.cta ?? (lang==='de'?'Mehr erfahren':'Learn more')} →</a>}
    </aside>
  )}

  <!-- THE ONE ASK: subscribe -->
  <section class="subcard">
    <h2>{tx.subH}</h2>
    <p>{tx.subP}</p>
    <a class="cta" href={`/${lang}/subscribe`}>{tx.subBtn}</a>
  </section>

  <!-- QUIET PROVENANCE -->
  {sources.length > 0 && (
    <section class="srcblock">
      <p class="kick">{tx.sources}</p>
      <ol>
        {sources.map((item) => (
          <li><a href={item.readMore} target="_blank" rel="noopener">{item.headline}</a></li>
        ))}
      </ol>
    </section>
  )}
</Base>

<style>
  .crumb a{color:inherit;text-decoration:none}
  .player{border:1px solid var(--line);border-radius:14px;padding:16px;background:var(--panel);display:flex;flex-direction:column;gap:12px}
  audio{filter:invert(1) hue-rotate(180deg)}
  .listen{display:flex;flex-wrap:wrap;align-items:center;gap:10px}
  .ll{font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--g3)}
  .lp{font-size:13px;font-weight:700;text-decoration:none;color:var(--chalk);border:1px solid var(--line);border-radius:999px;padding:6px 13px;transition:border-color .15s ease,background .15s ease}
  .lp:hover{border-color:var(--chalk);background:var(--chalk);color:var(--ink)}

  .digest{list-style:none;margin:14px 0 0;padding:0;border-top:1px solid var(--line)}
  .digest li{display:grid;grid-template-columns:38px 1fr;gap:14px;padding:20px 0;border-bottom:1px solid var(--line);align-items:start}
  .dn{font-family:ui-monospace,Menlo,monospace;font-size:13px;color:var(--g4);padding-top:6px}
  .pillar-chip{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--g3)}
  .digest h3{font-size:21px;line-height:1.2;letter-spacing:-.02em;margin:7px 0 6px;font-weight:800}
  .digest .dek{color:var(--g2);font-size:15.5px;line-height:1.6;margin:0}

  .movecard{margin-top:16px;border:1px solid var(--line);border-radius:14px;padding:18px 18px 16px;background:var(--panel)}
  .movecard .kick{margin:0 0 8px}
  .move-note{font-size:18px;font-weight:700;line-height:1.35;color:var(--chalk);margin:0 0 12px;letter-spacing:-.01em}
  .move-link{display:inline-block;font-size:13px;font-weight:800;color:var(--ink);background:var(--chalk);text-decoration:none;padding:9px 16px;border-radius:999px}
  .move-credit{display:block;margin-top:10px;font-size:12px;color:var(--g3)}
  .dots{margin-top:20px;padding-top:18px;border-top:1px solid var(--line)}
  .dots h2{font-size:25px;line-height:1.2;letter-spacing:-.02em;margin:8px 0 10px}
  .dotbody{color:var(--g1);font-size:16.5px;line-height:1.7;margin:0 0 12px;max-width:62ch}
  .dothis{margin-top:24px}
  .dothis-box{margin-top:8px;background:var(--chalk);color:var(--ink);border-radius:14px;padding:18px 20px;font-size:16px;line-height:1.6;font-weight:600}
  .mw{margin-top:24px}
  .mwbody{color:var(--g1);font-size:15.5px;line-height:1.7;margin:8px 0 0;max-width:62ch}
  .recs{margin-top:24px}
  .reclist{margin:10px 0 0;padding:0;list-style:none}
  .reclist li{padding:10px 0;border-top:1px solid var(--line);color:var(--g1);font-size:15px;line-height:1.55}
  .reclist b{color:var(--chalk)}
  .reclist a{color:var(--chalk);text-decoration:none;border-bottom:1px solid var(--g3)}
  .reclist a:hover{border-color:var(--chalk)}
  .recad{font-size:9px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--g4);margin-left:6px}

  .sponsor{margin-top:22px;border:1px dashed var(--line);border-radius:14px;padding:18px 20px;background:var(--panel)}
  .sponsor .adlabel{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--g4)}
  .sponsor p{margin:8px 0 12px;color:var(--g1);font-size:15.5px;line-height:1.55}
  .sponsor .lp{display:inline-block}

  .subcard{margin-top:26px;border:1px solid var(--line);border-radius:16px;padding:28px;text-align:center;background:linear-gradient(180deg,var(--panel),transparent)}
  .subcard h2{font-size:24px;letter-spacing:-.02em;margin:0 0 8px}
  .subcard p{color:var(--g2);max-width:46ch;margin:0 auto 18px;line-height:1.55}
  .subcard .cta{display:inline-block}

  .srcblock{margin-top:30px;padding-top:18px;border-top:1px solid var(--line)}
  .srcblock ol{margin:10px 0 0;padding-left:20px;color:var(--g3)}
  .srcblock li{font-size:13px;line-height:1.7}
  .srcblock a{color:var(--g3);text-decoration:none;border-bottom:1px solid var(--line)}
  .srcblock a:hover{color:var(--chalk);border-color:var(--chalk)}

  @media(max-width:520px){
    .digest li{grid-template-columns:26px 1fr;gap:10px}
    .digest h3{font-size:19px}
    .subcard{padding:22px 16px}
  }
</style>
