---
import { t, type Lang } from '../i18n/ui';
interface Props { lang: Lang; active?: string; altPath?: string }
const { lang, active = '', altPath } = Astro.props;
const other = lang === 'en' ? 'de' : 'en';
const otherHref = altPath ?? `/${other}/`;
---
<header class="site">
  <div class="wrap bar">
    <a class="logo" href={`/${lang}/`}><img class="logo-mark" src="/sqwod-white.png" alt="Sqwod" width="76" height="20" /><span>.life</span></a>
    <nav class="main">
      <a href={`/${lang}/daily`} class={active==='daily'?'on':''}>{t(lang,'nav.daily')}</a>
      <a href={`/${lang}/intelligence`} class={active==='intelligence'?'on':''}>{t(lang,'nav.intelligence')}</a>
      <a href={`/${lang}/articles`} class={active==='articles'?'on':''}>{t(lang,'nav.articles')}</a>
      <a href={`/${lang}/verified`} class={active==='verified'?'on':''}>{t(lang,'nav.verified')}</a>
      <a href={`/${lang}/about`} class={active==='about'?'on':''}>{t(lang,'nav.about')}</a>
    </nav>
    <div class="utils">
      <a class="lang" href={otherHref}><b>{lang.toUpperCase()}</b> · {other.toUpperCase()}</a>
      <a class="cta" href={`/${lang}/subscribe`}>{t(lang,'nav.subscribe')}</a>
    </div>
  </div>
</header>
