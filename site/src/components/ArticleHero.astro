---
// Per-article animated hero. Same monochrome discipline, unique per article.
// When `art` is set, show that custom hand-drawn illustration full-bleed
// (pure illustration, no overlay); otherwise fall back to the generated viz.
interface Props { kind?: string; art?: string; tag?: string; stat?: string; statLabel?: string }
const { kind = 'line', art, tag, stat, statLabel } = Astro.props;
---
{art ? (
  <div class="arthero has-art">
    <img class="ah-art" src={art} alt="" loading="lazy" decoding="async" />
  </div>
) : (
<div class="arthero">
  <div class="ah-viz">
    {kind === 'line' && (
      <div class="ah-line">
        <svg viewBox="0 0 800 200" preserveAspectRatio="none">
          <line class="gl" x1="0" y1="55" x2="800" y2="55"/><line class="gl" x1="0" y1="110" x2="800" y2="110"/>
          <path class="ln" d="M10 120 L150 98 L280 112 L420 66 L560 82 L700 34 L790 48"/>
        </svg>
      </div>
    )}
    {kind === 'bars' && (<div class="ah-bars"><i></i><i></i><i></i><i></i><i></i><i></i></div>)}
    {kind === 'orbit' && (
      <div class="ah-orbit"><span class="o1"></span><span class="o2"></span><span class="o3"></span><span class="od"><b></b></span></div>
    )}
    {kind === 'lattice' && (
      <div class="ah-lattice">
        <svg viewBox="0 0 300 150" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <path class="bond" d="M172 75 L150 113 L106 113 L84 75 L106 37 L150 37 Z"/>
          <line class="bond" x1="172" y1="75" x2="216" y2="75"/>
          <line class="bond" x1="84" y1="75" x2="46" y2="75"/>
          <path class="current" d="M172 75 L150 113 L106 113 L84 75 L106 37 L150 37 Z"/>
          <circle class="node n1" cx="172" cy="75" r="5"/>
          <circle class="node n2" cx="150" cy="113" r="5"/>
          <circle class="node n3" cx="106" cy="113" r="5"/>
          <circle class="node n4" cx="84" cy="75" r="5"/>
          <circle class="node n5" cx="106" cy="37" r="5"/>
          <circle class="node n6" cx="150" cy="37" r="5"/>
          <circle class="node n2" cx="46" cy="75" r="4.5"/>
          <circle class="ping" cx="216" cy="75" r="6"/>
          <circle class="hot" cx="216" cy="75" r="6"/>
        </svg>
      </div>
    )}
  </div>

  <div class="scrim"></div>
  {tag && <span class="ah-tag">{tag}</span>}
  {stat && <div class="ah-stat">{stat}{statLabel && <small>{statLabel}</small>}</div>}
</div>
)}
