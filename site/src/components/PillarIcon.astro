---
// Consistent, distinct wayfinding icon per pillar. Used wherever a pillar appears.
interface Props { pillar: string; size?: number; framed?: boolean }
const { pillar, size = 52, framed = true } = Astro.props;
const i = Math.round(size * 0.5);
---
<div class={`glyphbox pillaricon${framed ? '' : ' bare'}`} style={`width:${size}px;height:${size}px${framed ? '' : ';background:none;border:none'}`} aria-hidden="true">
  <svg width={i} height={i} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
    {pillar === 'business-strategy' && (
      <g><polyline points="3 17 9 11 13 14 21 6"/><polyline points="15 6 21 6 21 12"/></g>
    )}
    {pillar === 'marketing-visibility' && (
      <g><path d="M4 10v4h3l10 4V6L7 10H4z"/><path d="M19 9.5a3.5 3.5 0 0 1 0 5"/></g>
    )}
    {pillar === 'operations-technology' && (
      <g><line x1="4" y1="8" x2="20" y2="8"/><circle cx="15" cy="8" r="2.1"/><line x1="4" y1="16" x2="20" y2="16"/><circle cx="9" cy="16" r="2.1"/></g>
    )}
    {pillar === 'industry-trends' && (
      <g><line x1="3.5" y1="20" x2="20.5" y2="20"/><rect x="5" y="12" width="3" height="7" rx="0.5"/><rect x="10.5" y="8" width="3" height="11" rx="0.5"/><rect x="16" y="4" width="3" height="15" rx="0.5"/></g>
    )}
    {pillar === 'founder-stories' && (
      <g><circle cx="12" cy="8" r="3.3"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></g>
    )}
    {pillar === 'ai-automation' && (
      <g><path d="M12 3l1.7 6.3L20 11l-6.3 1.7L12 19l-1.7-6.3L4 11l6.3-1.7z"/><circle cx="18.5" cy="5.5" r="1"/></g>
    )}
  </svg>
</div>
