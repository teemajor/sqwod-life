---
// Wayfinding icon per lane (move | build | gear | signal). Used wherever a lane appears.
interface Props { pillar: string; size?: number; framed?: boolean }
const { pillar, size = 52, framed = true } = Astro.props;
const i = Math.round(size * 0.5);
---
<div class={`glyphbox pillaricon${framed ? '' : ' bare'}`} style={`width:${size}px;height:${size}px${framed ? '' : ';background:none;border:none'}`} aria-hidden="true">
  <svg width={i} height={i} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
    {pillar === 'move' && (
      <g><line x1="3" y1="12" x2="21" y2="12"/><rect x="3.5" y="8.5" width="2.6" height="7" rx="0.6"/><rect x="17.9" y="8.5" width="2.6" height="7" rx="0.6"/><line x1="6.1" y1="12" x2="7.6" y2="12"/><line x1="16.4" y1="12" x2="17.9" y2="12"/></g>
    )}
    {pillar === 'build' && (
      <g><rect x="3.5" y="13" width="7" height="7" rx="1"/><rect x="13.5" y="13" width="7" height="7" rx="1"/><rect x="8.5" y="4.5" width="7" height="7" rx="1"/></g>
    )}
    {pillar === 'gear' && (
      <g><path d="M3.5 11.2 11 3.7h6.3v6.3l-7.5 7.5z"/><circle cx="14.2" cy="6.8" r="1.2"/></g>
    )}
    {pillar === 'signal' && (
      <g><path d="M5 13.5a7 7 0 0 1 14 0"/><path d="M8 13.5a4 4 0 0 1 8 0"/><circle cx="12" cy="13.5" r="1.3"/></g>
    )}
  </svg>
</div>
