---
import { t, type Lang } from '../i18n/ui';
interface Props { lang: Lang; glb?: string; glyph?: 'ring' | 'watch' | 'band' | 'tracker' | 'massager' | 'bed' | 'supplement' }
const { lang, glb, glyph = 'ring' } = Astro.props;
---
<div class="viewer" id="viewer" data-glb={glb ?? ''} data-glyph={glyph}>
  <span class="dots">◈ 360°</span>
  <span class="hint" id="viewer-hint">{t(lang,'spin')}</span>
</div>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script is:inline>
(function(){
  var mount = document.getElementById('viewer');
  if(!mount || !window.THREE){ if(mount){ mount.innerHTML += '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#85858e;font-size:12px">3D preview needs an internet connection</div>'; } return; }
  var glyph = mount.getAttribute('data-glyph') || 'ring';
  var W = mount.clientWidth, H = mount.clientHeight;
  var scene = new THREE.Scene();
  var camera = new THREE.PerspectiveCamera(40, W/H, 0.1, 100); camera.position.set(0,0,6);
  var renderer = new THREE.WebGLRenderer({antialias:true, alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2)); renderer.setSize(W,H); mount.appendChild(renderer.domElement);

  // monochrome, stylized materials (NOT brand replicas — Sqwod-mono representations)
  var chrome = new THREE.MeshStandardMaterial({color:0xf2f2f4,metalness:0.95,roughness:0.28});
  var ink    = new THREE.MeshStandardMaterial({color:0x141417,metalness:0.4,roughness:0.7});
  var glass  = new THREE.MeshStandardMaterial({color:0x0a0a0c,metalness:0.6,roughness:0.15});
  var group = new THREE.Group();

  function box(w,h,d,m){ return new THREE.Mesh(new THREE.BoxGeometry(w,h,d), m); }
  function buildWatch(){
    var g=new THREE.Group();
    var caseM=box(2.0,2.4,0.55,ink); g.add(caseM);            // case
    var face=box(1.7,2.05,0.08,glass); face.position.z=0.30; g.add(face); // screen
    var crown=new THREE.Mesh(new THREE.CylinderGeometry(0.12,0.12,0.3,24),chrome); crown.rotation.z=Math.PI/2; crown.position.set(1.05,0.3,0.05); g.add(crown);
    var strapT=box(1.2,1.4,0.30,ink); strapT.position.y=1.85; g.add(strapT);
    var strapB=box(1.2,1.4,0.30,ink); strapB.position.y=-1.85; g.add(strapB);
    g.scale.set(0.95,0.95,0.95); return g;
  }
  function buildRing(){
    var g=new THREE.Group();
    var outer=new THREE.Mesh(new THREE.TorusGeometry(1.5,0.55,64,160),chrome); g.add(outer);
    var inner=new THREE.Mesh(new THREE.TorusGeometry(1.5,0.40,48,160),ink); inner.scale.set(1,1,0.55); g.add(inner);
    g.rotation.x=0.6; return g;
  }
  function buildBand(){ // screenless loop (Whoop-style)
    var g=new THREE.Group();
    var loop=new THREE.Mesh(new THREE.TorusGeometry(1.6,0.22,32,160),ink); loop.scale.set(1,1.25,0.6); g.add(loop);
    var sensor=box(0.9,0.7,0.32,chrome); sensor.position.z=0.55; g.add(sensor);
    g.rotation.x=0.5; return g;
  }
  function buildTracker(){ // pill module on a thin band (Fitbit-style)
    var g=new THREE.Group();
    var loop=new THREE.Mesh(new THREE.TorusGeometry(1.6,0.16,32,160),ink); loop.scale.set(1,1.3,0.55); g.add(loop);
    var mod=box(0.8,1.5,0.34,ink); mod.position.z=0.5; g.add(mod);
    var face=box(0.6,1.25,0.06,glass); face.position.z=0.69; g.add(face);
    g.rotation.x=0.5; return g;
  }
  function buildMassager(){ // percussion gun: handle + angled head
    var g=new THREE.Group();
    var handle=new THREE.Mesh(new THREE.CylinderGeometry(0.34,0.40,2.1,32),ink); handle.position.y=-0.6; g.add(handle);
    var neck=new THREE.Mesh(new THREE.CylinderGeometry(0.22,0.22,0.9,24),chrome); neck.position.set(0,0.7,0); g.add(neck);
    var head=new THREE.Mesh(new THREE.SphereGeometry(0.5,32,24),chrome); head.position.set(0,1.25,0); g.add(head);
    var tip=new THREE.Mesh(new THREE.SphereGeometry(0.26,24,18),ink); tip.position.set(0,1.7,0); g.add(tip);
    g.rotation.z=0.25; return g;
  }
  function buildBed(){ // mattress / temp cover: flat rounded box
    var g=new THREE.Group();
    var base=new THREE.Mesh(new THREE.BoxGeometry(3.2,0.5,2.2),ink); g.add(base);
    var top=new THREE.Mesh(new THREE.BoxGeometry(3.0,0.18,2.0),chrome); top.position.y=0.34; g.add(top);
    var pillow=new THREE.Mesh(new THREE.BoxGeometry(1.1,0.3,0.7),chrome); pillow.position.set(-0.85,0.5,-0.5); g.add(pillow);
    g.rotation.x=0.5; g.rotation.y=-0.4; return g;
  }
  function buildSupplement(){ // tub / bottle: cylinder + lid
    var g=new THREE.Group();
    var body=new THREE.Mesh(new THREE.CylinderGeometry(0.95,0.95,1.9,48),chrome); g.add(body);
    var lid=new THREE.Mesh(new THREE.CylinderGeometry(1.0,1.0,0.45,48),ink); lid.position.y=1.15; g.add(lid);
    var band=new THREE.Mesh(new THREE.CylinderGeometry(0.97,0.97,0.7,48),ink); band.position.y=-0.1; band.scale.set(1,1,1); g.add(band);
    return g;
  }
  var model = glyph==='watch'?buildWatch() : glyph==='band'?buildBand() : glyph==='tracker'?buildTracker()
    : glyph==='massager'?buildMassager() : glyph==='bed'?buildBed() : glyph==='supplement'?buildSupplement() : buildRing();
  group.add(model); scene.add(group);

  scene.add(new THREE.AmbientLight(0xffffff,0.35));
  var key=new THREE.DirectionalLight(0xffffff,1.1); key.position.set(3,4,5); scene.add(key);
  var rim=new THREE.DirectionalLight(0xffffff,0.6); rim.position.set(-4,-2,-3); scene.add(rim);
  var top=new THREE.PointLight(0xffffff,0.5); top.position.set(0,5,2); scene.add(top);

  var dragging=false,lastX=0,lastY=0,idle=true,hid=false,hint=document.getElementById('viewer-hint');
  function pt(e){ if(e.touches&&e.touches[0]) return {x:e.touches[0].clientX,y:e.touches[0].clientY}; return {x:e.clientX,y:e.clientY}; }
  mount.addEventListener('pointerdown',function(e){dragging=true;idle=false;mount.classList.add('drag');var p=pt(e);lastX=p.x;lastY=p.y;if(!hid){hint.style.opacity=0;hid=true;}});
  window.addEventListener('pointermove',function(e){if(!dragging)return;var p=pt(e);group.rotation.y+=(p.x-lastX)*0.01;group.rotation.x+=(p.y-lastY)*0.01;lastX=p.x;lastY=p.y;});
  window.addEventListener('pointerup',function(){dragging=false;mount.classList.remove('drag');setTimeout(function(){idle=true;},1500);});
  mount.addEventListener('wheel',function(e){e.preventDefault();camera.position.z=Math.max(4,Math.min(9,camera.position.z+(e.deltaY>0?0.4:-0.4)));},{passive:false});
  var pinchD=0;
  mount.addEventListener('touchmove',function(e){if(e.touches.length===2){e.preventDefault();var dx=e.touches[0].clientX-e.touches[1].clientX,dy=e.touches[0].clientY-e.touches[1].clientY,d=Math.hypot(dx,dy);if(pinchD){camera.position.z=Math.max(4,Math.min(9,camera.position.z+(pinchD-d)*0.01));}pinchD=d;}},{passive:false});
  mount.addEventListener('touchend',function(){pinchD=0;});
  window.addEventListener('resize',function(){W=mount.clientWidth;H=mount.clientHeight;camera.aspect=W/H;camera.updateProjectionMatrix();renderer.setSize(W,H);});
  (function loop(){requestAnimationFrame(loop);if(idle&&!dragging){group.rotation.y+=0.006;}renderer.render(scene,camera);})();
})();
</script>
