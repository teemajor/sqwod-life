---
// Per-article topical glyph: hand-drawn-style white line art on a black frame
// (no colour, no fill). Each icon self-sketches via the shared `draw` keyframe,
// so it reads like an illustration being drawn by hand. Pick one per article
// with the `icon` frontmatter field; otherwise it falls back to a per-pillar
// default so nothing is ever generic.
interface Props { icon?: string; pillar?: string; size?: number; framed?: boolean }
const { icon, pillar = '', size = 52, framed = true } = Astro.props;

const ICONS = ['smart-ring','recovery','retention','ai-prompt','growth','megaphone','automation','market','founder','ai-spark'] as const;
const PILLAR_ICON: Record<string, string> = {
  'business-strategy': 'growth',
  'marketing-visibility': 'megaphone',
  'operations-technology': 'automation',
  'industry-trends': 'market',
  'founder-stories': 'founder',
  'ai-automation': 'ai-spark',
};

const key = icon && (ICONS as readonly string[]).includes(icon) ? icon : (PILLAR_ICON[pillar] ?? 'market');
const i = Math.round(size * 0.62);
const boxStyle = `width:${size}px;height:${size}px` + (framed ? '' : ';background:none;border:none');
---
<div class={`glyphbox artglyph${framed ? '' : ' bare'}`} style={boxStyle} aria-hidden="true">
  <svg width={i} height={i} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    {key === 'smart-ring' && (
      <g>
        <path d="M11 12.5V6a1.7 1.7 0 0 1 3.4 0v6.5"/>
        <path d="M10.5 8.3h4.4v2.1h-4.4z"/>
        <path d="M12 7.5l1 1-1 1-1-1z"/>
        <path d="M11 12.5c-1.5.2-2.5 1.3-2.5 3v3.5h7.9V15c0-1.5-.6-2.3-2-2.5"/>
        <path d="M8.6 14.6 6.7 16"/>
        <path d="M18.2 4.8v2.4M17 6h2.4"/>
      </g>
    )}
    {key === 'recovery' && (
      <g>
        <rect x="3.5" y="8.5" width="14" height="7" rx="2"/>
        <path d="M17.7 10.8h1.5v2.4h-1.5"/>
        <path d="M10.8 9.6 8.6 12.4h1.9L9.2 15.4"/>
      </g>
    )}
    {key === 'retention' && (
      <g>
        <path d="M7 4v6a5 5 0 0 0 10 0V4"/>
        <path d="M10 4v6a2 2 0 0 0 4 0V4"/>
        <path d="M5.4 4h3.6M15 4h3.6"/>
        <path d="M12 17.6v2.3M9.3 18.5l-.7.8M14.7 18.5l.7.8"/>
      </g>
    )}
    {key === 'ai-prompt' && (
      <g>
        <path d="M4 6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H9l-3.2 2.8V13H6a2 2 0 0 1-2-2z"/>
        <path d="M11 6.4l.9 2.2 2.2.9-2.2.9-.9 2.2-.9-2.2L7.9 9.5l2.2-.9z"/>
      </g>
    )}
    {key === 'growth' && (
      <g>
        <polyline points="3 16.5 9 10.5 13 13.5 21 5.5"/>
        <polyline points="15.5 5.5 21 5.5 21 11"/>
      </g>
    )}
    {key === 'megaphone' && (
      <g>
        <path d="M4 10v4h3l10 4.2V5.8L7 10H4z"/>
        <path d="M19.5 9.2a3.6 3.6 0 0 1 0 5.6"/>
        <path d="M8 14.4v3.1a1.4 1.4 0 0 0 2.6.6"/>
      </g>
    )}
    {key === 'automation' && (
      <g>
        <circle cx="12" cy="12" r="3.2"/>
        <path d="M12 3.6v2.6M12 17.8v2.6M3.6 12h2.6M17.8 12h2.6M6.1 6.1l1.8 1.8M16.1 16.1l1.8 1.8M17.9 6.1l-1.8 1.8M7.9 16.1l-1.8 1.8"/>
      </g>
    )}
    {key === 'market' && (
      <g>
        <path d="M3.5 20h17"/>
        <rect x="5" y="12" width="3" height="7" rx="0.5"/>
        <rect x="10.5" y="8" width="3" height="11" rx="0.5"/>
        <rect x="16" y="4.5" width="3" height="14.5" rx="0.5"/>
      </g>
    )}
    {key === 'founder' && (
      <g>
        <circle cx="11" cy="8" r="3.2"/>
        <path d="M5 20a6 6 0 0 1 12 0"/>
        <path d="M19 4v2.6M17.7 5.3h2.6"/>
      </g>
    )}
    {key === 'ai-spark' && (
      <g>
        <path d="M12 3.2l2 6.3 6.3 1.5-6.3 1.5-2 6.3-2-6.3L3.7 11l6.3-1.5z"/>
        <path d="M18.4 4.6v2.2M17.3 5.7h2.2"/>
      </g>
    )}
  </svg>
</div>
