---
// Per-article topical glyph: an elaborate, lightly-coloured line icon that
// reads at a glance (you can tell the topic without the title) yet stays in
// the site's monochrome-frame discipline. Pick one per article via the
// `icon` frontmatter field; otherwise it falls back to a per-pillar default.
interface Props { icon?: string; pillar?: string; size?: number; framed?: boolean }
const { icon, pillar = '', size = 52, framed = true } = Astro.props;

const ICONS = ['smart-ring','recovery','retention','ai-prompt','growth','megaphone','automation','market','founder','ai-spark'] as const;
const PILLAR_ICON: Record<string, string> = {
  'business-strategy': 'growth',
  'marketing-visibility': 'megaphone',
  'operations-technology': 'automation',
  'industry-trends': 'market',
  'founder-stories': 'founder',
  'ai-automation': 'ai-spark',
};
const ACCENT: Record<string, string> = {
  'smart-ring': '#67e8f9', 'recovery': '#5fd39a', 'retention': '#f5b651', 'ai-prompt': '#a78bfa',
  'growth': '#5fd39a', 'megaphone': '#fb9b6a', 'automation': '#6aa8fb', 'market': '#5fd0c0',
  'founder': '#f5b651', 'ai-spark': '#a78bfa',
};

const key = icon && (ICONS as readonly string[]).includes(icon) ? icon : (PILLAR_ICON[pillar] ?? 'market');
const ac = ACCENT[key] ?? '#9aa0ff';
const i = Math.round(size * 0.58);
const boxStyle = `width:${size}px;height:${size}px;--ac:${ac}` + (framed ? '' : ';background:none;border:none');
---
<div class={`glyphbox artglyph${framed ? '' : ' bare'}`} style={boxStyle} aria-hidden="true">
  <svg width={i} height={i} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    {key === 'smart-ring' && (
      <g>
        <rect x="9" y="2.5" width="6" height="19" rx="3"/>
        <ellipse class="ac" cx="12" cy="13.6" rx="4.7" ry="2.3"/>
        <circle class="fill dot" cx="12" cy="11.3" r="1.05"/>
        <path class="ac spark" d="M18.4 4.6v2.8M17 6h2.8"/>
      </g>
    )}
    {key === 'recovery' && (
      <g>
        <g transform="rotate(-40 12 12)">
          <rect x="4.5" y="9.6" width="15" height="4.8" rx="2.4"/>
          <line x1="12" y1="9.6" x2="12" y2="14.4"/>
        </g>
        <path class="fill leaf" d="M16 4c2.7.1 4.1 1.5 4.3 4.2-2.7-.1-4.1-1.5-4.3-4.2z"/>
      </g>
    )}
    {key === 'retention' && (
      <g>
        <path d="M7.3 3.5v7a4.7 4.7 0 0 0 9.4 0v-7"/>
        <path class="fill" d="M5.2 3h4.2v3.6H5.2z"/>
        <path class="fill" d="M14.6 3h4.2v3.6h-4.2z"/>
        <circle class="ac dot" cx="12" cy="20" r="1.1"/>
        <path d="M9.8 18.2 8.3 19.6M14.2 18.2 15.7 19.6"/>
      </g>
    )}
    {key === 'ai-prompt' && (
      <g>
        <rect x="3.5" y="5" width="13.5" height="9" rx="2.2"/>
        <path d="M7.2 14v3.2l3.6-3.2"/>
        <path class="fill" d="M9.4 7.2l.85 2.1 2.1.85-2.1.85-.85 2.1-.85-2.1-2.1-.85 2.1-.85z"/>
        <circle class="ac" cx="17.8" cy="17.2" r="3.2"/>
        <path class="ac" d="M17.8 15.6v1.7l1.2.8"/>
      </g>
    )}
    {key === 'growth' && (
      <g>
        <polyline points="3 16.5 9 10.5 13 13.5 21 5.5"/>
        <polyline class="ac" points="15 5.5 21 5.5 21 11.5"/>
      </g>
    )}
    {key === 'megaphone' && (
      <g>
        <path d="M4 10v4h3l10 4.2V5.8L7 10H4z"/>
        <path class="ac" d="M19.5 9.2a3.6 3.6 0 0 1 0 5.6"/>
      </g>
    )}
    {key === 'automation' && (
      <g>
        <circle cx="12" cy="12" r="3.3"/>
        <g class="ac">
          <line x1="12" y1="3.6" x2="12" y2="6.2"/><line x1="12" y1="17.8" x2="12" y2="20.4"/>
          <line x1="3.6" y1="12" x2="6.2" y2="12"/><line x1="17.8" y1="12" x2="20.4" y2="12"/>
          <line x1="6.1" y1="6.1" x2="7.9" y2="7.9"/><line x1="16.1" y1="16.1" x2="17.9" y2="17.9"/>
          <line x1="17.9" y1="6.1" x2="16.1" y2="7.9"/><line x1="7.9" y1="16.1" x2="6.1" y2="17.9"/>
        </g>
      </g>
    )}
    {key === 'market' && (
      <g>
        <line x1="3.5" y1="20" x2="20.5" y2="20"/>
        <rect x="5" y="12" width="3" height="7" rx="0.5"/>
        <rect x="10.5" y="8" width="3" height="11" rx="0.5"/>
        <rect class="fill" x="16" y="4.5" width="3" height="14.5" rx="0.5"/>
      </g>
    )}
    {key === 'founder' && (
      <g>
        <circle cx="11" cy="8" r="3.2"/>
        <path d="M5 20a6 6 0 0 1 12 0"/>
        <path class="ac spark" d="M19 4v2.6M17.7 5.3h2.6"/>
      </g>
    )}
    {key === 'ai-spark' && (
      <g>
        <path class="fill" d="M12 3l1.9 6.3L20 11l-6.1 1.7L12 19l-1.9-6.3L4 11l6.1-1.7z"/>
        <circle class="fill" cx="18.6" cy="5.4" r="1"/>
      </g>
    )}
  </svg>
</div>
