---
import { type Lang } from '../i18n/ui';
import { pillarMeta, type Pillar } from '../i18n/pillars';
import ArticleHero from './ArticleHero.astro';
import ShareBar from './ShareBar.astro';
import BenchmarkWidget from './BenchmarkWidget.astro';
import { SUBSCRIBE } from '../config/subscribe';
import type { CollectionEntry } from 'astro:content';
import type { RelatedItem } from '../lib/related';
interface Props { lang: Lang; entry: CollectionEntry<'articles'>; sectionLabel: string; related?: RelatedItem[] }
const { lang, entry, sectionLabel, related = [] } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
const pillar = pillarMeta[d.pillar as Pillar];
const fmt = d.publishedAt.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
const sharePath = `/${lang}/${sectionLabel.toLowerCase() === 'intelligence' ? 'intelligence' : 'articles'}/${d.urlSlug}`;
const locked = d.gated;
const U = lang === 'de'
  ? { head: 'Vollständigen Report freischalten', body: 'Kostenlos. Trag deine E-Mail ein — du liest sofort weiter und bekommst den Daily.', ph: 'E-Mail-Adresse', cta: 'Freischalten', fine: 'Sqwod Daily, werktäglich. Jederzeit abbestellbar.' }
  : { head: 'Unlock the full report', body: "Free. Drop your email — you'll keep reading instantly and get the Daily.", ph: 'Email address', cta: 'Unlock', fine: 'Sqwod Daily, every weekday. Unsubscribe anytime.' };

// --- Download + cite (credibility / GEO / backlinks): build CSV + JSON of the
// report's own facts, plus a copy-paste citation. All from real data — nothing made up. ---
const reportUrl = new URL(Astro.url.pathname, Astro.site).toString();
const csvCell = (s: unknown) => `"${String(s ?? '').replace(/"/g, '""')}"`;
const csvRows: string[] = [];
if (d.figures?.length) {
  csvRows.push(['Figure', 'Value', 'Note', 'Source'].join(','));
  for (const f of d.figures) csvRows.push([f.label, f.value, f.note, f.source].map(csvCell).join(','));
}
if (d.series && d.series.points.length) {
  if (csvRows.length) csvRows.push('');
  csvRows.push(`${d.series.label}${d.series.unit ? ` (${d.series.unit})` : ''}`);
  const hasBand = !!(d.series.low && d.series.high);
  csvRows.push((hasBand ? ['Year', 'Low', 'Value', 'High'] : ['Year', 'Value']).join(','));
  d.series.points.forEach((p, i) => {
    const yr = d.series!.years?.[i] ?? String(i);
    csvRows.push((hasBand ? [yr, d.series!.low![i], p, d.series!.high![i]] : [yr, p]).map(csvCell).join(','));
  });
}
const csv = csvRows.join('\n');
const csvHref = csv ? `data:text/csv;charset=utf-8,${encodeURIComponent(csv)}` : '';
const jsonHref = `data:application/json;charset=utf-8,${encodeURIComponent(JSON.stringify({ title: d.title, asOf: d.asOf, url: reportUrl, figures: d.figures, series: d.series, sources: d.sources }, null, 2))}`;
const citation = `${d.author}. "${d.title}." sqwod.life${d.asOf ? `, ${d.asOf}` : ''}. ${reportUrl}`;
// Link each figure to its source: explicit figure.url wins, else auto-match the
// figure's `source` label to a citation in `sources[]` (by its leading token).
const figSourceUrl = (f: { source?: string; url?: string }) => {
  if (f.url) return f.url;
  if (!f.source || !d.sources?.length) return null;
  const key = f.source.split(/[·,/]/)[0].trim().toLowerCase();
  if (!key) return null;
  return d.sources.find((s) => s.label.toLowerCase().includes(key))?.url ?? null;
};
const hasData = !!(csv || (d.figures && d.figures.length));
// --- Figure micro-charts: classify a value string and draw an inline accent viz.
// % → a meter (single fill or low–high band); × → a multiplier bar vs a 1× line;
// anything else ($bn, M, counts) → a short accent keyline (no fabricated data). ---
function vizOf(value: string) {
  const v = String(value);
  const nums = (v.match(/\d+(?:[.,]\d+)?/g) || []).map((n) => parseFloat(n.replace(',', '.')));
  if (/%/.test(v) && nums.length) {
    const [a, b] = nums.length >= 2 ? [nums[0], nums[1]] : [0, nums[0]];
    return { type: 'meter', a, b, max: 100 } as const;
  }
  if (/[×x]/i.test(v) && nums.length) {
    const hi = nums[nums.length - 1];
    return { type: 'mult', hi, max: Math.max(hi * 1.18, 2) } as const;
  }
  return { type: 'rule' } as const;
}
function figVizSvg(z: ReturnType<typeof vizOf>) {
  const W = 300;
  if (z.type === 'meter') {
    const xa = Math.max(0, (z.a / z.max) * W), bw = Math.max((z.b / z.max) * W - xa, 5);
    return `<svg class="fviz" viewBox="0 0 ${W} 14" preserveAspectRatio="xMidYMid meet" aria-hidden="true">`
      + `<rect x="0" y="4" width="${W}" height="6" rx="3" fill="var(--panel2)"/>`
      + `<rect x="${xa.toFixed(1)}" y="2" width="${bw.toFixed(1)}" height="10" rx="5" fill="var(--accent)"/></svg>`;
  }
  if (z.type === 'mult') {
    const wHi = (z.hi / z.max) * W, x1 = (1 / z.max) * W;
    return `<svg class="fviz" viewBox="0 0 ${W} 14" preserveAspectRatio="xMidYMid meet" aria-hidden="true">`
      + `<rect x="0" y="4" width="${W}" height="6" rx="3" fill="var(--panel2)"/>`
      + `<rect x="0" y="2" width="${wHi.toFixed(1)}" height="10" rx="5" fill="var(--accent)"/>`
      + `<line x1="${x1.toFixed(1)}" y1="0" x2="${x1.toFixed(1)}" y2="14" stroke="var(--g2)" stroke-width="1.5"/></svg>`;
  }
  return `<svg class="fviz fviz-rule" viewBox="0 0 ${W} 6" preserveAspectRatio="xMidYMid meet" aria-hidden="true"><rect x="0" y="2" width="72" height="4" rx="2" fill="var(--accent)"/></svg>`;
}
const TX = lang === 'de'
  ? { tldr: 'Das Wichtigste', means: 'Was das für dich heißt', data: 'Daten & Quelle', dl: 'Daten (CSV)', dlj: 'JSON', cite: 'Diesen Report zitieren', copy: 'Kopieren', copied: 'Kopiert ✓', now: 'jetzt', share: 'Als Bild teilen', tag: 'SQWOD INTELLIGENCE', board: 'Scoreboard teilen', boardEye: 'Zahlen, die zählen', boardTitle: 'IN ZAHLEN', verdict: 'Verdict teilen', real: 'Belegt durch Studien', hype: 'Glaub dem Hype nicht' }
  : { tldr: 'Key takeaways', means: 'What this means for you', data: 'Data & citation', dl: 'Data (CSV)', dlj: 'JSON', cite: 'Cite this report', copy: 'Copy', copied: 'Copied ✓', now: 'now', share: 'Share as image', tag: 'SQWOD INTELLIGENCE', board: 'Share scoreboard', boardEye: 'Figures that matter', boardTitle: 'BY THE NUMBERS', verdict: 'Share verdict', real: 'Backed by trials', hype: "Don't buy the hype" };
// data the share-image script needs (brand strings + the chart series + figures + verdict), passed to the client below
const V = d.verdict;
const shareCfg = {
  url: reportUrl, asOf: d.asOf ?? '', tag: TX.tag, share: TX.share, accent: '#C7F24C',
  section: (sectionLabel || '').toUpperCase(),
  boardEye: TX.boardEye, boardTitle: TX.boardTitle,
  figures: (d.figures ?? []).map((f) => ({ v: f.value, l: f.label, n: f.note ?? '', s: f.source ?? '' })),
  series: d.series ? { label: d.series.label, unit: d.series.unit ?? '', points: d.series.points, years: d.series.years ?? [] } : null,
  verdict: V ? {
    title: V.title || (d.title || '').toUpperCase(),
    realLabel: (V.realLabel || TX.real), hypeLabel: (V.hypeLabel || TX.hype),
    real: V.real ?? [], hype: V.hype ?? [], note: V.note ?? '',
  } : null,
};
---
<div class="crumb">{sectionLabel} · {pillar.label[lang]}</div>
<h1>{d.title}</h1>
<p class="sub">{d.description}</p>

{d.hero && <ArticleHero kind={d.hero.kind} art={d.hero.art} tag={pillar.label[lang]} stat={d.hero.stat} statLabel={d.hero.statLabel} />}
<div class="meta" style="margin:8px 0 0;color:var(--g3);font-size:12px">
  {d.author} · {fmt}
  {locked && <span class="conf" style="margin-left:8px">{lang==='de'?'Free + gegated':'Free · gated'}</span>}
</div>

<ShareBar path={sharePath} title={d.title} lang={lang} />

{d.takeaways && d.takeaways.length > 0 && (
  <section class="block tldr">
    <p class="kick">{TX.tldr}</p>
    <ul class="tldr-list">
      {d.takeaways.map((t) => <li>{t}</li>)}
    </ul>
  </section>
)}

{d.figures && d.figures.length > 0 && (
  <section class="block figs">
    <div class="figs-head">
      <p class="kick" style="margin:0">{lang==='de'?'Zahlen, die zählen':'Figures that matter'}</p>
      <div class="figs-actions">
        {d.verdict && ((d.verdict.real?.length ?? 0) + (d.verdict.hype?.length ?? 0) > 0) && (
          <button class="share-btn" type="button" data-kind="verdict" aria-label={TX.verdict}>◐ {TX.verdict}</button>
        )}
        {d.figures.length > 1 && (
          <button class="share-btn" type="button" data-kind="board" aria-label={TX.board}>▦ {TX.board}</button>
        )}
      </div>
    </div>
    <div class="fig-grid">
      {d.figures.map((f) => (
        <div class="fig">
          <div class="fig-val">{f.value}</div>
          <Fragment set:html={figVizSvg(vizOf(f.value))} />
          <div class="fig-lbl">{f.label}</div>
          {f.note && <div class="fig-note">{f.note}</div>}
          {f.source && (figSourceUrl(f)
            ? <a class="fig-src fig-src-link" href={figSourceUrl(f)!} target="_blank" rel="nofollow noopener">{f.source} ↗</a>
            : <div class="fig-src">{f.source}</div>)}
          <button class="fig-share share-btn" type="button" data-kind="stat" data-v={f.value} data-l={f.label} data-n={f.note ?? ''} data-s={f.source ?? ''} aria-label={TX.share}>↗ {TX.share}</button>
        </div>
      ))}
    </div>
  </section>
)}

{d.benchmark && <BenchmarkWidget lang={lang} benchmark={d.benchmark} />}

{d.series && d.series.points.length > 1 && (() => {
  const s = d.series;
  const pts = s.points;
  const yrs = s.years || [];
  const hasBand = !!(s.low && s.high && s.low.length === pts.length && s.high.length === pts.length);
  const mx = Math.max(...(hasBand ? s.high! : pts), 1);
  const W = 720, H = 264, top = 42, bot = 30, base = H - bot, chartH = base - top;
  const slot = W / pts.length;
  const barW = Math.min(48, slot * 0.55);
  const nowYear = String(new Date().getFullYear());
  const anyNow = yrs.includes(nowYear); // if no bar is the current year, emphasise the latest/forecast bar instead
  const yOf = (v: number) => base - Math.max(2, (v / mx) * chartH);
  return (
    <section class="block chart">
      <p class="kick">{s.label}{s.unit ? ` · ${s.unit}` : ''}</p>
      <div class="chart-wrap">
        <svg class="bars-svg" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid meet" role="img" aria-label={s.label}>
          <line x1="0" y1={base} x2={W} y2={base} stroke="var(--line)" stroke-width="1" />
          {pts.map((p, i) => {
            const h = base - yOf(p);
            const x = i * slot + (slot - barW) / 2;
            const cx = i * slot + slot / 2;
            const isNow = yrs[i] === nowYear;
            const emph = isNow || (!anyNow && i === pts.length - 1);
            const yoy = i > 0 && pts[i - 1] ? Math.round(((p - pts[i - 1]) / pts[i - 1]) * 1000) / 10 : '';
            return (
              <g class="bar-g" tabindex="0" role="button" aria-label={`${yrs[i] ?? ''}: ${p}${s.unit ? ' ' + s.unit : ''}`}
                 data-year={yrs[i] ?? ''} data-val={p} data-unit={s.unit ?? ''} data-yoy={yoy} data-now={isNow ? '1' : ''}>
                {hasBand && <rect x={cx - barW / 2 - 3} y={yOf(s.high![i])} width={barW + 6} height={Math.max(1, yOf(s.low![i]) - yOf(s.high![i]))} rx="4" fill="var(--accent)" opacity="0.16" />}
                <rect class="bar-r" x={x} y={base - h} width={barW} height={h} rx="4" fill={emph ? 'var(--accent)' : 'var(--chalk)'} opacity={emph ? '1' : '0.78'} />
                {emph && <rect x={x - 2} y={base - h - 2} width={barW + 4} height={h + 2} rx="5" fill="none" stroke="var(--accent)" stroke-width="2" />}
                <text x={cx} y={base - h - 9} text-anchor="middle" fill={emph ? 'var(--accent)' : 'var(--g2)'} font-size="13" font-family="ui-monospace,Menlo,monospace">{p}</text>
                {isNow && <text x={cx} y={top - 10} text-anchor="middle" fill="var(--accent)" font-size="11" font-weight="700" font-family="ui-monospace,Menlo,monospace">▼ {TX.now}</text>}
                {yrs[i] && <text x={cx} y={base + 20} text-anchor="middle" fill={emph ? 'var(--accent)' : 'var(--g4)'} font-size="12" font-family="ui-monospace,Menlo,monospace">{yrs[i]}</text>}
              </g>
            );
          })}
        </svg>
        <div class="chart-tip" id="chartTip" hidden></div>
      </div>
      <button class="share-btn chart-share" type="button" data-kind="chart" aria-label={TX.share}>↗ {TX.share}</button>
      {hasBand && <p class="src-note" style="margin-top:8px">{lang === 'de' ? 'Schattierter Bereich = Spanne verschiedener Prognosehäuser (Low–High).' : 'Shaded band = range across forecasters (low–high).'}</p>}
    </section>
  );
})()}

{d.playbook && d.playbook.length > 0 && (
  <section class="block playbook">
    <p class="kick">◆ {TX.means}</p>
    <div class="pb-grid">
      {d.playbook.map((p) => (
        <div class="pb">
          <div class="pb-move">{p.move}</div>
          <div class="pb-why">{p.why}</div>
        </div>
      ))}
    </div>
  </section>
)}

<div class="report-body" data-gated={locked ? '' : undefined}>
  <section class="block prose" style="border-top:1px solid var(--line);margin-top:18px">
    <Content />
  </section>

  {d.sources && d.sources.length > 0 && (
    <section class="block sources-block">
      <p class="kick">{lang==='de'?'Quellen':'Sources'}</p>
      <ol class="src-list">
        {d.sources.map((s) => <li><a href={s.url} target="_blank" rel="nofollow noopener">{s.label} ↗</a></li>)}
      </ol>
      <p class="src-note">{lang==='de'
        ? `Zahlen aus öffentlichen Quellen${d.asOf ? `, Stand ${d.asOf}` : ''}. Schätzungen verschiedener Häuser variieren; wir verlinken, damit du selbst prüfen kannst.`
        : `Figures from public sources${d.asOf ? `, as of ${d.asOf}` : ''}. Estimates vary between firms; we link them so you can verify.`}</p>
    </section>
  )}

  {d.changelog && d.changelog.length > 0 && (
    <section class="block changelog">
      <p class="kick">{lang==='de'?'Aktualisierungen':'Update log'}</p>
      <ul class="cl-list">
        {d.changelog.map((c) => <li><b>{c.date}</b> — {c.note}</li>)}
      </ul>
      <p class="src-note">{lang==='de'?'Lebender Report — wir aktualisieren die Zahlen regelmäßig.':'Living report — we refresh the figures on a regular cadence.'}</p>
    </section>
  )}
</div>

{locked && (
  <div class="unlock" id="unlock">
    <div class="unlock-card">
      <div class="unlock-head">{U.head}</div>
      <p class="unlock-body">{U.body}</p>
      <form class="unlock-form">
        <input type="email" name="email" required placeholder={U.ph} aria-label={U.ph} />
        <button class="cta" type="submit" data-umami-event="report-unlock" data-umami-event-report={d.urlSlug}>{U.cta} →</button>
      </form>
      <p class="unlock-fine">{U.fine}</p>
    </div>
  </div>
)}

{hasData && (
  <section class="block data-cite">
    <p class="kick">{TX.data}</p>
    <div class="dc-row">
      {csvHref && <a class="dc-btn" href={csvHref} download={`${d.urlSlug}.csv`}>↓ {TX.dl}</a>}
      <a class="dc-btn" href={jsonHref} download={`${d.urlSlug}.json`}>↓ {TX.dlj}</a>
      <button class="dc-btn copy" id="citeCopy" type="button" data-copy={`⧉ ${TX.cite}`} data-done={TX.copied}>⧉ {TX.cite}</button>
    </div>
    <figure class="cite-card">
      <figcaption class="cite-cap">{TX.cite}</figcaption>
      <blockquote class="cite-quote" id="citeText">{citation}</blockquote>
    </figure>
  </section>
)}

{related && related.length > 0 && (
  <section class="block related">
    <p class="kick">{lang==='de'?'Weiterlesen':'Related'}</p>
    <div class="grid cols2">
      {related.map((r) => (
        <a class="card rel-card" href={r.href}>
          <div class="info">
            <span class="bestfor">{r.kind}</span>
            <h3>{r.title}</h3>
            <div class="meta">{r.desc}</div>
            <span class="cardcta">{lang==='de'?'Ansehen':'Read'} →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<section class="block" style="border-bottom:none">
  <a class="cta" href={`/${lang}/articles/${d.pillar}`}>{lang==='de'?'Mehr aus':'More in'} {pillar.label[lang]} →</a>
</section>

<style>
  .figs-head{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
  .figs-actions{display:flex;gap:8px;flex-wrap:wrap;margin-left:auto}
  .fig-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(168px,1fr));gap:14px;margin-top:14px}
  .fig{display:flex;flex-direction:column;border:1px solid var(--line);border-radius:14px;padding:16px 16px 14px;background:linear-gradient(180deg,var(--panel),var(--bg));transition:border-color .15s ease,box-shadow .15s ease}
  .fig:hover{border-color:var(--accent-line);box-shadow:0 0 0 1px var(--accent-line),0 8px 30px rgba(0,0,0,.35)}
  .fig-val{font-size:30px;font-weight:900;letter-spacing:-.02em;line-height:1;color:var(--accent)}
  .fviz{width:100%;height:14px;display:block;margin:13px 0 2px}
  .fviz.fviz-rule{height:6px;margin:11px 0 2px}
  .fig-lbl{font-size:13.5px;font-weight:600;color:var(--chalk);margin-top:9px;line-height:1.3}
  .fig-note{font-size:12px;color:var(--g3);margin-top:6px;line-height:1.45}
  .fig-src{font-size:10px;letter-spacing:.05em;text-transform:uppercase;color:var(--g4);margin-top:10px}
  .bars-svg{width:100%;height:auto;display:block;margin-top:14px}
  .chart .bars{display:flex;align-items:flex-end;gap:8px;height:160px;margin-top:14px;border-bottom:1px solid var(--line);padding-bottom:0}
  .bar-col{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%}
  .bar{width:100%;max-width:46px;background:var(--chalk);border-radius:4px 4px 0 0;position:relative;min-height:3px;display:flex;justify-content:center}
  .bar-v{position:absolute;top:-18px;font-size:10px;color:var(--g2);font-family:ui-monospace,Menlo,monospace}
  .bar-y{font-size:10px;color:var(--g4);margin-top:6px;font-family:ui-monospace,Menlo,monospace}
  .cl-list{list-style:none;margin:10px 0 0;padding:0}
  .cl-list li{font-size:13.5px;color:var(--g2);padding:6px 0;border-top:1px solid var(--line)}
  .cl-list b{color:var(--chalk);font-family:ui-monospace,Menlo,monospace;font-size:12px}
  /* gated lead-magnet: figures + chart are the teaser; body fades behind the unlock */
  .report-body[data-gated]{max-height:320px;overflow:hidden;-webkit-mask-image:linear-gradient(180deg,#000 58%,transparent);mask-image:linear-gradient(180deg,#000 58%,transparent)}
  .report-body.open{max-height:none;-webkit-mask-image:none;mask-image:none}
  .unlock{margin:6px 0 8px}
  .unlock-card{border:1px solid var(--line);border-radius:16px;padding:24px 22px;background:linear-gradient(180deg,var(--panel),transparent);text-align:center}
  .unlock-head{font-size:20px;font-weight:900;letter-spacing:-.01em}
  .unlock-body{font-size:14.5px;color:var(--g2);margin:8px 0 16px;line-height:1.55}
  .unlock-form{display:flex;gap:10px;max-width:440px;margin:0 auto;flex-wrap:wrap;justify-content:center}
  .unlock-form input{flex:1;min-width:200px;background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:12px 14px;color:var(--chalk);font:inherit}
  .unlock-form input:focus{outline:none;border-color:var(--chalk)}
  .unlock-fine{font-size:11.5px;color:var(--g4);margin:12px 0 0}

  /* TL;DR */
  .tldr-list{list-style:none;margin:10px 0 0;padding:0;display:grid;gap:8px}
  .tldr-list li{position:relative;padding:10px 14px 10px 34px;border:1px solid var(--line);border-radius:10px;background:var(--panel);font-size:14.5px;line-height:1.5;color:var(--g1)}
  .tldr-list li::before{content:"→";position:absolute;left:13px;top:10px;color:var(--accent);font-weight:800}
  /* interactive chart */
  .chart-wrap{position:relative}
  .bar-g{cursor:default;transition:opacity .12s ease}
  .bar-g:hover .bar-r,.bar-g:focus .bar-r{opacity:1}
  .bar-g:focus{outline:none}
  .bar-g:focus .bar-r{stroke:var(--chalk);stroke-width:2}
  .chart-tip{position:absolute;pointer-events:none;z-index:5;background:var(--bg);border:1px solid var(--chalk);border-radius:8px;padding:7px 10px;font-size:12px;line-height:1.4;color:var(--chalk);transform:translate(-50%,-110%);white-space:nowrap;box-shadow:0 4px 18px rgba(0,0,0,.3)}
  .chart-tip b{font-family:ui-monospace,Menlo,monospace}
  .chart-tip .yoy-up{color:var(--up)}.chart-tip .yoy-dn{color:var(--down)}
  /* operator playbook */
  .pb-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;margin-top:12px}
  .pb{border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:10px;padding:13px 15px;background:var(--panel)}
  .pb-move{font-size:14.5px;font-weight:800;letter-spacing:-.01em;line-height:1.3}
  .pb-why{font-size:13px;color:var(--g2);margin-top:6px;line-height:1.5}
  /* data + cite */
  .dc-row{display:flex;gap:10px;flex-wrap:wrap;margin:0 0 14px}
  .dc-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;border:1px solid var(--line);border-radius:999px;padding:8px 15px;text-decoration:none;color:var(--chalk);background:var(--panel);cursor:pointer;font-family:inherit;transition:border-color .15s,color .15s}
  .dc-btn:hover{border-color:var(--accent);color:var(--accent)}
  .cite-card{margin:0;border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:12px;padding:14px 16px;background:var(--panel)}
  .cite-cap{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--g4);margin:0 0 8px}
  .cite-quote{margin:0;font-size:13.5px;line-height:1.6;color:var(--g1);word-break:break-word}
  a.fig-src{text-decoration:none;display:block}
  a.fig-src-link:hover{color:var(--chalk)}
  .rel-card{grid-template-columns:1fr !important}
  /* share-as-image + bottom utility strip */
  .share-btn{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:700;letter-spacing:.02em;border:1px solid var(--line);border-radius:999px;padding:6px 12px;background:var(--panel);color:var(--g2);cursor:pointer;font-family:inherit;transition:border-color .15s,color .15s,background .15s}
  .share-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-soft)}
  .share-btn.busy{opacity:.55;pointer-events:none}
  .fig-share{margin-top:auto;padding-top:14px;align-self:flex-start}   /* pin to card bottom so a row of cards lines up evenly */
  .chart-share{margin-top:12px}
</style>

<script define:vars={{ endpoint: SUBSCRIBE.endpoint, lang, locked }}>
  if (locked) {
    const KEY = 'sqwod_unlocked';
    const reveal = () => {
      document.querySelectorAll('.report-body[data-gated]').forEach((el) => { el.removeAttribute('data-gated'); el.classList.add('open'); });
      const u = document.getElementById('unlock'); if (u) u.style.display = 'none';
    };
    if (localStorage.getItem(KEY) === '1') reveal();
    const form = document.querySelector('.unlock-form');
    if (form) form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (form.email.value || '').trim();
      const btn = form.querySelector('button'); if (btn) { btn.disabled = true; btn.textContent = '…'; }
      if (endpoint && email) {
        try { await fetch(endpoint, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ email, lang }) }); } catch (_) {}
      }
      localStorage.setItem(KEY, '1');
      reveal();
    });
  }
</script>

<script define:vars={{ yoyLabel: lang === 'de' ? 'ggü. Vorjahr' : 'YoY' }}>
  // Chart tooltips: year · value · YoY, shown on hover/focus of each bar.
  (function () {
    const tip = document.getElementById('chartTip');
    const wrap = tip && tip.closest('.chart-wrap');
    if (tip && wrap) {
      const show = (g) => {
        const yr = g.getAttribute('data-year'), val = g.getAttribute('data-val');
        const unit = g.getAttribute('data-unit'), yoy = g.getAttribute('data-yoy');
        const now = g.getAttribute('data-now');
        let html = `<b>${val}</b>${unit ? ' ' + unit : ''}${yr ? ` · ${yr}` : ''}${now ? ' · ' + 'now' : ''}`;
        if (yoy !== '' && yoy !== null) {
          const up = parseFloat(yoy) >= 0;
          html += `<br><span class="${up ? 'yoy-up' : 'yoy-dn'}">${up ? '▲' : '▼'} ${Math.abs(parseFloat(yoy))}% ${yoyLabel}</span>`;
        }
        tip.innerHTML = html;
        const gb = g.getBoundingClientRect(), wb = wrap.getBoundingClientRect();
        tip.style.left = (gb.left - wb.left + gb.width / 2) + 'px';
        tip.style.top = (gb.top - wb.top) + 'px';
        tip.hidden = false;
      };
      const hide = () => { tip.hidden = true; };
      wrap.querySelectorAll('.bar-g').forEach((g) => {
        g.addEventListener('mouseenter', () => show(g));
        g.addEventListener('focus', () => show(g));
        g.addEventListener('mouseleave', hide);
        g.addEventListener('blur', hide);
      });
    }
    // Copy-to-clipboard for the citation.
    const btn = document.getElementById('citeCopy'), txt = document.getElementById('citeText');
    if (btn && txt) btn.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(txt.textContent || ''); } catch (_) {}
      btn.textContent = btn.getAttribute('data-done');
      setTimeout(() => { btn.textContent = btn.getAttribute('data-copy'); }, 1800);
    });
  })();
</script>

<script define:vars={{ shareCfg }}>
  // Share as image — render a figure (hook), the full scoreboard, or the chart into a
  // self-contained, on-brand 1600×900 PNG: near-black canvas, radial lime glow, giant
  // stat, Sqwod wordmark + source + URL. Data-bound to the article's own figures.
  // Literal hex colors only (CSS vars don't survive SVG→canvas rasterization); pure SVG
  // (no foreignObject) keeps the canvas untainted so toBlob works for Web Share/download.
  (function () {
    const accent = shareCfg.accent || '#C7F24C';
    const C = { ink: '#0A0B0A', chalk: '#F4F5F0', g1: '#C9CFC0', g2: '#9AA093', g3: '#8A8F86', g4: '#6B6F64', dim: '#5B5F55', accent };
    // Heavy system stack (rasterization can't fetch page/Google fonts — approximate Archivo/Space Mono)
    const SANS = "'Helvetica Neue',Helvetica,Arial,system-ui,sans-serif";
    const MONO = "ui-monospace,'SF Mono',Menlo,Consolas,monospace";
    const W = 1600, H = 900, PADX = 96;
    const section = shareCfg.section || shareCfg.tag || 'SQWOD';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const prettyUrl = (u) => String(u || '').replace(/^https?:\/\//, '').replace(/\/$/, '');
    const wrap = (s, max) => { const ws = String(s || '').split(/\s+/); const out = []; let cur = ''; for (const w of ws) { if ((cur + ' ' + w).trim().length > max) { if (cur) out.push(cur); cur = w; } else cur = (cur ? cur + ' ' : '') + w; } if (cur) out.push(cur); return out; };
    const clip = (s, n) => { s = String(s || ''); return s.length > n ? s.slice(0, n - 1).trimEnd() + '…' : s; };
    const lines = (arr, x, y, dy, attrs) => arr.map((t, i) => `<text x="${x}" y="${y + i * dy}" ${attrs}>${esc(t)}</text>`).join('');

    // Shared chrome: ink canvas + radial lime glow (top-left), wordmark, section kicker, footer strip.
    const card = (inner, footL, footR) =>
      `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">` +
      `<defs><radialGradient id="glow" cx="20%" cy="6%" r="62%">` +
        `<stop offset="0%" stop-color="${accent}" stop-opacity="0.14"/>` +
        `<stop offset="66%" stop-color="${accent}" stop-opacity="0"/>` +
      `</radialGradient></defs>` +
      `<rect width="${W}" height="${H}" fill="${C.ink}"/>` +
      `<rect width="${W}" height="${H}" fill="url(#glow)"/>` +
      `<text x="${PADX}" y="118" font-family="${SANS}" font-weight="800" font-size="48" letter-spacing="1" fill="${C.chalk}">SQWOD</text>` +
      `<text x="${W - PADX}" y="112" text-anchor="end" font-family="${MONO}" font-size="22" letter-spacing="5" fill="${C.g3}">${esc(section)}</text>` +
      inner +
      `<line x1="${PADX}" y1="${H - 120}" x2="${W - PADX}" y2="${H - 120}" stroke="#FFFFFF" stroke-opacity="0.10" stroke-width="1.5"/>` +
      `<text x="${PADX}" y="${H - 66}" font-family="${MONO}" font-size="22" letter-spacing="1" fill="${C.g3}">${esc(clip(footL, 74))}</text>` +
      `<text x="${W - PADX}" y="${H - 66}" text-anchor="end" font-family="${MONO}" font-size="22" letter-spacing="3" fill="${accent}">${esc(footR || 'SQWOD.LIFE')}</text>` +
      `</svg>`;

    // Hook — one figure, giant lime stat over supporting label + note.
    const statInner = (d) => {
      const v = String(d.v || ''), L = v.length;
      const vs = L <= 4 ? 300 : L <= 7 ? 220 : L <= 12 ? 150 : L <= 20 ? 100 : 68;
      const ls = vs >= 220 ? '-8' : vs >= 100 ? '-4' : '-2';
      let inner = `<text x="${PADX}" y="380" font-family="${SANS}" font-weight="800" font-size="${vs}" letter-spacing="${ls}" fill="${accent}">${esc(v)}</text>`;
      const lbl = wrap(d.l, 40).slice(0, 2);
      inner += lines(lbl, PADX, 470, 62, `font-family="${SANS}" font-weight="800" font-size="52" letter-spacing="-1" fill="${C.chalk}"`);
      if (d.n) inner += lines(wrap(d.n, 66).slice(0, 3), PADX, 470 + lbl.length * 62 + 30, 40, `font-family="${SANS}" font-size="30" fill="${C.g2}"`);
      return inner;
    };

    // Scoreboard — up to 6 figures in a 3×2 hairline grid (all of the article's figures at once).
    const boardInner = () => {
      const figs = (shareCfg.figures || []).slice(0, 6);
      if (!figs.length) return '';
      let inner = `<text x="${PADX}" y="186" font-family="${MONO}" font-size="22" letter-spacing="5" fill="${accent}">${esc((shareCfg.boardEye || '').toUpperCase())}</text>`;
      inner += `<text x="${PADX}" y="272" font-family="${SANS}" font-weight="800" font-size="76" letter-spacing="-2" fill="${C.chalk}">${esc(shareCfg.boardTitle || 'BY THE NUMBERS')}</text>`;
      const cols = 3, rows = 2, gridTop = 330, gridBot = H - 150;
      const colW = (W - PADX * 2) / cols, rowH = (gridBot - gridTop) / rows;
      // hairline dividers
      for (let c = 1; c < cols; c++) inner += `<line x1="${PADX + c * colW}" y1="${gridTop}" x2="${PADX + c * colW}" y2="${gridTop + rows * rowH}" stroke="#FFFFFF" stroke-opacity="0.09" stroke-width="1"/>`;
      inner += `<line x1="${PADX}" y1="${gridTop + rowH}" x2="${W - PADX}" y2="${gridTop + rowH}" stroke="#FFFFFF" stroke-opacity="0.09" stroke-width="1"/>`;
      figs.forEach((f, i) => {
        const cx = PADX + (i % cols) * colW + 8, cy = gridTop + Math.floor(i / cols) * rowH;
        const v = String(f.v || ''), L = v.length;
        const vs = L <= 4 ? 88 : L <= 7 ? 72 : L <= 12 ? 52 : 38;
        inner += `<text x="${cx}" y="${cy + 78}" font-family="${SANS}" font-weight="800" font-size="${vs}" letter-spacing="-1" fill="${accent}">${esc(v)}</text>`;
        const lbl = wrap(f.l, 30); const lbl2 = lbl.length > 2 ? [lbl[0], lbl.slice(1).join(' ').slice(0, 28).trimEnd() + '…'] : lbl;
        inner += lines(lbl2, cx, cy + 120, 28, `font-family="${SANS}" font-weight="700" font-size="22" fill="${C.chalk}"`);
        if (f.s) inner += `<text x="${cx}" y="${cy + rowH - 14}" font-family="${MONO}" font-size="15" letter-spacing="1" fill="${C.g4}">${esc(clip(f.s, 38).toUpperCase())}</text>`;
      });
      return inner;
    };

    // Verdict — opinionated "what's real vs. hype" two-panel card (1C).
    const verdictInner = () => {
      const V = shareCfg.verdict; if (!V) return '';
      const t = String(V.title || '').toUpperCase();
      const tl = wrap(t, 30).slice(0, 2), tsz = t.length <= 18 ? 66 : t.length <= 30 ? 52 : 42;
      let inner = lines(tl, PADX, 234, tsz + 8, `font-family="${SANS}" font-weight="800" font-size="${tsz}" letter-spacing="-1" fill="${C.chalk}"`);
      const top = tl.length > 1 ? 330 : 300, bottom = H - 150, gap = 40, pw = (W - PADX * 2 - gap) / 2, ph = bottom - top;
      const panel = (x, isReal, label, rows) => {
        const col = isReal ? accent : '#FFFFFF', so = isReal ? 0.34 : 0.14, fo = isReal ? 0.05 : 0.0;
        let g = `<rect x="${x}" y="${top}" width="${pw}" height="${ph}" rx="16" fill="${col}" fill-opacity="${fo}" stroke="${col}" stroke-opacity="${so}"/>`;
        g += `<text x="${x + 40}" y="${top + 60}" font-family="${MONO}" font-size="19" letter-spacing="3" fill="${isReal ? accent : C.g2}">${esc(label)}</text>`;
        const rr = rows.slice(0, 2), area = ph - 96, rowH = area / Math.max(rr.length, 1), ry0 = top + 96;
        rr.forEach((r, i) => {
          const cy = ry0 + i * rowH + rowH / 2, v = String(r.value || ''), vs = v.length <= 4 ? 60 : v.length <= 7 ? 46 : 34;
          g += `<text x="${x + 40}" y="${cy + vs * 0.34}" font-family="${SANS}" font-weight="800" font-size="${vs}" letter-spacing="-1" fill="${isReal ? accent : C.dim}">${esc(v)}</text>`;
          const tx = x + 40 + 200, txt = wrap(r.text, 37).slice(0, 3);
          g += lines(txt, tx, cy - (txt.length - 1) * 13 + 7, 26, `font-family="${SANS}" font-weight="600" font-size="20" fill="${isReal ? C.chalk : C.g1}"`);
        });
        return g;
      };
      inner += panel(PADX, true, '✓ ' + (V.realLabel || ''), V.real || []);
      inner += panel(PADX + pw + gap, false, '✕ ' + (V.hypeLabel || ''), V.hype || []);
      return inner;
    };

    const chartInner = () => {
      const s = shareCfg.series; if (!s) return '';
      const pts = s.points, yrs = s.years || [];
      const x0 = PADX, x1 = W - PADX, top = 320, base = 720, mx = Math.max.apply(null, pts.concat([1]));
      const slot = (x1 - x0) / pts.length, bw = Math.min(90, slot * 0.5), nowY = String(new Date().getFullYear());
      const anyNow = yrs.indexOf(nowY) >= 0;
      let inner = `<text x="${PADX}" y="196" font-family="${MONO}" font-size="22" letter-spacing="5" fill="${accent}">${esc((shareCfg.boardEye || '').toUpperCase())}</text>`;
      inner += `<text x="${PADX}" y="266" font-family="${SANS}" font-weight="800" font-size="52" letter-spacing="-1" fill="${C.chalk}">${esc(s.label)}${s.unit ? '  ·  ' + esc(s.unit) : ''}</text>`;
      inner += `<line x1="${x0}" y1="${base}" x2="${x1}" y2="${base}" stroke="#FFFFFF" stroke-opacity="0.10" stroke-width="1.5"/>`;
      pts.forEach((p, i) => {
        const h = Math.max(4, (p / mx) * (base - top)), x = x0 + i * slot + (slot - bw) / 2, cx = x0 + i * slot + slot / 2;
        const emph = yrs[i] === nowY || (!anyNow && i === pts.length - 1);
        inner += `<rect x="${x}" y="${base - h}" width="${bw}" height="${h}" rx="6" fill="${emph ? accent : C.chalk}" opacity="${emph ? 1 : 0.72}"/>`;
        inner += `<text x="${cx}" y="${base - h - 16}" text-anchor="middle" font-family="${MONO}" font-size="26" fill="${emph ? accent : C.g2}">${p}</text>`;
        if (yrs[i]) inner += `<text x="${cx}" y="${base + 38}" text-anchor="middle" font-family="${MONO}" font-size="22" fill="${emph ? accent : C.g4}">${esc(yrs[i])}</text>`;
      });
      return inner;
    };

    const rasterize = (svg, filename) => {
      const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml;charset=utf-8' }));
      const img = new Image();
      img.onload = () => {
        const sc = 2, cv = document.createElement('canvas'); cv.width = W * sc; cv.height = H * sc;
        const ctx = cv.getContext('2d'); ctx.scale(sc, sc); ctx.drawImage(img, 0, 0); URL.revokeObjectURL(url);
        cv.toBlob(async (png) => {
          if (!png) return;
          const file = new File([png], filename, { type: 'image/png' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            try { await navigator.share({ files: [file], title: 'Sqwod Intelligence' }); return; } catch (_) {}
          }
          const a = document.createElement('a'); a.href = URL.createObjectURL(png); a.download = filename; document.body.appendChild(a); a.click(); a.remove();
        }, 'image/png');
      };
      img.onerror = () => URL.revokeObjectURL(url);
      img.src = url;
    };

    const asOfFoot = shareCfg.asOf ? 'As of ' + shareCfg.asOf : prettyUrl(shareCfg.url);
    document.querySelectorAll('.share-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.classList.add('busy');
        let svg, fn;
        if (btn.dataset.kind === 'verdict' && shareCfg.verdict) {
          svg = card(verdictInner(), shareCfg.verdict.note || asOfFoot);
          fn = 'sqwod-verdict.png';
        } else if (btn.dataset.kind === 'board' && (shareCfg.figures || []).length) {
          svg = card(boardInner(), asOfFoot);
          fn = 'sqwod-scoreboard.png';
        } else if (btn.dataset.kind === 'chart' && shareCfg.series) {
          svg = card(chartInner(), asOfFoot);
          fn = 'sqwod-chart.png';
        } else {
          const d = { v: btn.dataset.v, l: btn.dataset.l, n: btn.dataset.n, s: btn.dataset.s };
          svg = card(statInner(d), d.s ? 'Source: ' + d.s : asOfFoot);
          fn = 'sqwod-figure.png';
        }
        rasterize(svg, fn);
        setTimeout(() => btn.classList.remove('busy'), 1400);
      });
    });
  })();
</script>
